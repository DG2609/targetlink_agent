# ══════════════════════════════════════════════════════════
# Google Cloud Vertex AI — SAO CHÉP FILE NÀY THÀNH .env
# ══════════════════════════════════════════════════════════

# BẮT BUỘC
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Model
GEMINI_MODEL=gemini-2.0-flash-001

# Xác thực — CHỌN 1:
# Cách 1 (dev local): gcloud auth application-default login  → không cần set gì thêm
# Cách 2 (CI/CD):
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Pipeline
MAX_RETRY_AGENT4=3
MAX_RETRY_AGENT5=3
SANDBOX_TIMEOUT=30
