# ══════════════════════════════════════════════════════════
# TargetLink Config — SAO CHEP FILE NAY THANH .env
# ══════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────
# "gemini" = Google Vertex AI (cloud), "ollama" = local Ollama, "vllm" = vLLM server
LLM_PROVIDER=gemini

# ── Google Cloud Vertex AI (khi LLM_PROVIDER=gemini) ──────
# BAT BUOC khi dung gemini
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GEMINI_MODEL=gemini-2.0-flash-001

# Xac thuc — CHON 1:
# Cach 1 (dev local): gcloud auth application-default login
# Cach 2 (CI/CD):
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# ── Ollama (khi LLM_PROVIDER=ollama) ─────────────────────
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_HOST=http://localhost:11434
# Model nho hon cho Agent 0, 1, 1.5 (rong = dung OLLAMA_MODEL)
OLLAMA_SMALL_MODEL=

# ── vLLM (khi LLM_PROVIDER=vllm) ──────────────────────────
# vLLM serve OpenAI-compatible API — dung OpenAIChat cua Agno
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-32B-Instruct
# Model nho hon cho Agent 0 (rong = dung VLLM_MODEL)
VLLM_SMALL_MODEL=
VLLM_API_KEY=not-needed

# ── Pipeline ──────────────────────────────────────────────
MAX_RETRY_AGENT4=3
MAX_RETRY_AGENT5=3
SANDBOX_TIMEOUT=30
LLM_TIMEOUT=120
MAX_CONCURRENT_RULES=3
STDOUT_TRUNCATION=5000
STDERR_TRUNCATION=3000
CACHE_SUMMARY_LIMIT=2000
